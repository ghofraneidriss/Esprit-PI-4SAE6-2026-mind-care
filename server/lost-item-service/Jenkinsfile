pipeline {
    agent any

    environment {
        MAVEN_HOME = '/usr/share/maven'
        JAVA_HOME = '/usr/lib/jvm/java-21-openjdk-amd64'
    }

    stages {
        stage('Checkout') {
            steps {
                echo '========== Checking out code =========='
                checkout scm
            }
        }

        stage('Build') {
            steps {
                echo '========== Building lost-item-service =========='
                dir('server/lost-item-service') {
                    sh 'mvn clean compile'
                }
            }
        }

        stage('Test') {
            steps {
                echo '========== Running Unit Tests =========='
                dir('server/lost-item-service') {
                    sh 'mvn test -Dspring.profiles.active=test'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                echo '========== SonarQube Code Quality Analysis =========='
                dir('server/lost-item-service') {
                    sh '''
                        mvn sonar:sonar \
                            -Dsonar.projectKey=lost-item-service \
                            -Dsonar.projectName="Lost Item Service" \
                            -Dsonar.host.url=http://localhost:9000 \
                            -Dsonar.token=squ_dff9542226b4cffdf2772f4212689ed2879cb019 \
                            -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml \
                            -Dsonar.exclusions=**/*Test.java \
                            -Dsonar.coverage.exclusions=**/*Test.java
                    '''
                }
            }
        }

        stage('Package') {
            steps {
                echo '========== Packaging Application =========='
                dir('server/lost-item-service') {
                    sh 'mvn package -DskipTests'
                }
            }
        }
    }

    post {
        always {
            echo '========== Pipeline Execution Completed =========='
            junit 'server/lost-item-service/target/surefire-reports/*.xml'
        }
        success {
            echo '✓ lost-item-service pipeline SUCCESS'
        }
        failure {
            echo '✗ lost-item-service pipeline FAILED'
        }
    }
}
