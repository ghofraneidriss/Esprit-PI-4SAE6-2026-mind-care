pipeline {
    agent any

    environment {
        SERVICE_NAME = 'lost-item-service'
        DOCKER_REGISTRY = 'ghofraneidriss'
        IMAGE_TAG = "${BUILD_NUMBER}"
    }

    options {
        timestamps()
        timeout(time: 1, unit: 'HOURS')
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {
        stage('Checkout') {
            steps {
                echo '🔄 Checking out code...'
                checkout scm
            }
        }

        stage('Build') {
            steps {
                echo '🔨 Building Maven project...'
                dir('server/lost-item-service') {
                    sh 'mvn clean compile'
                }
            }
        }

        stage('Test') {
            steps {
                echo '🧪 Running tests...'
                dir('server/lost-item-service') {
                    sh 'mvn test'
                }
            }
        }

        stage('Package') {
            steps {
                echo '📦 Packaging application...'
                dir('server/lost-item-service') {
                    sh 'mvn package -DskipTests'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                echo '📊 Running SonarQube analysis...'
                dir('server/lost-item-service') {
                    sh '''
                        TOKEN="${SONARQUBE_TOKEN:-admin}"
                        mvn sonar:sonar \
                          -Dsonar.projectKey=lost-item-service \
                          -Dsonar.sources=src/main \
                          -Dsonar.tests=src/test \
                          -Dsonar.host.url=http://localhost:9000 \
                          -Dsonar.login="${TOKEN}" \
                          || echo "SonarQube analysis skipped (server unavailable or auth failed)"
                    '''
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                echo '🐳 Building Docker image...'
                dir('server/lost-item-service') {
                    script {
                        sh '''
                            docker build \
                              -t ${DOCKER_REGISTRY}/${SERVICE_NAME}:${IMAGE_TAG} \
                              -t ${DOCKER_REGISTRY}/${SERVICE_NAME}:latest \
                              --label "build.number=${BUILD_NUMBER}" \
                              --label "git.commit=${GIT_COMMIT}" \
                              --label "jenkins.job=${JOB_NAME}" \
                              .
                        '''
                    }
                }
            }
        }

        stage('Push Docker Image') {
            when {
                branch 'jaaferFinal'
            }
            steps {
                echo '📤 Pushing Docker image to registry...'
                script {
                    sh '''
                        docker push ${DOCKER_REGISTRY}/${SERVICE_NAME}:${IMAGE_TAG} || echo "Docker push skipped (no credentials configured)"
                        docker push ${DOCKER_REGISTRY}/${SERVICE_NAME}:latest || echo "Docker push skipped (no credentials configured)"
                    '''
                }
            }
        }

        stage('Deploy') {
            when {
                branch 'jaaferFinal'
            }
            steps {
                echo '🚀 Deploying service...'
                script {
                    sh '''
                        docker-compose -f docker-compose.yml down lost-item-service || true
                        docker-compose -f docker-compose.yml up -d lost-item-service
                        sleep 10
                        docker-compose -f docker-compose.yml logs lost-item-service
                    '''
                }
            }
        }

        stage('Health Check') {
            steps {
                echo '❤️ Performing health checks...'
                script {
                    sh '''
                        MAX_RETRIES=30
                        RETRY_COUNT=0

                        while [ $RETRY_COUNT -lt $MAX_RETRIES ]; do
                            if nc -z localhost 8082 2>/dev/null; then
                                echo "✅ Service is healthy!"
                                exit 0
                            fi
                            RETRY_COUNT=$((RETRY_COUNT + 1))
                            echo "Health check attempt $RETRY_COUNT/$MAX_RETRIES..."
                            sleep 2
                        done

                        echo "❌ Service failed health check"
                        exit 1
                    '''
                }
            }
        }
    }

    post {
        always {
            echo '📝 Pipeline completed'
        }
        success {
            echo '✅ Pipeline completed successfully!'
        }
        failure {
            echo '❌ Pipeline failed!'
        }
    }
}
