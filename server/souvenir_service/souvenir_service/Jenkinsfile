pipeline {
    agent any

    tools {
        maven 'Maven3'
        jdk 'JDK21'
    }

    environment {
        DOCKERHUB_CREDENTIALS = credentials('dockerhub-credentials')
        SONAR_TOKEN            = credentials('sonar-token-souvenir')
        IMAGE_NAME             = "${DOCKERHUB_CREDENTIALS_USR}/souvenir-service"
        IMAGE_TAG              = "${env.BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                dir('server/souvenir_service/souvenir_service') {
                    sh 'mvn clean package -DskipTests'
                }
            }
        }

        stage('Tests Unitaires') {
            steps {
                dir('server/souvenir_service/souvenir_service') {
                    sh 'mvn test'
                }
            }
            post {
                always {
                    junit 'server/souvenir_service/souvenir_service/target/surefire-reports/TEST-*.xml'
                }
            }
        }

        stage('Analyse SonarQube') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    dir('server/souvenir_service/souvenir_service') {
                        sh """
                            mvn sonar:sonar \
                                -Dsonar.projectKey=souvenir_service \
                                -Dsonar.projectName=souvenir_service \
                                -Dsonar.login=${SONAR_TOKEN} \
                                -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml
                        """
                    }
                }
            }
        }

        stage('Build Image Docker') {
            steps {
                dir('server/souvenir_service/souvenir_service') {
                    sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
                    sh "docker tag ${IMAGE_NAME}:${IMAGE_TAG} ${IMAGE_NAME}:latest"
                }
            }
        }

        stage('Push Docker Hub') {
            steps {
                sh "echo ${DOCKERHUB_CREDENTIALS_PSW} | docker login -u ${DOCKERHUB_CREDENTIALS_USR} --password-stdin"
                sh "docker push ${IMAGE_NAME}:${IMAGE_TAG}"
                sh "docker push ${IMAGE_NAME}:latest"
            }
        }
    }

    post {
        success {
            echo "Pipeline souvenir_service réussi ✅"
        }
        failure {
            echo "Pipeline souvenir_service échoué ❌"
        }
        always {
            sh "docker logout"
        }
    }
}
