pipeline {
    agent any

    tools {
        maven 'M3'
    }

    stages {
        stage('Cleanup') {
            steps {
                sh 'find . -name "report-task.txt" -delete'
            }
        }

        stage('Checkout') {
            steps {
                git branch: 'Amena-Farah-Finale',
                        url: 'https://github.com/ghofraneidriss/Esprit-PI-4SAE6-2026-mind-care.git'
            }
        }

        stage('Build & Install Parent') {
            steps {
                dir('server') {
                    sh 'mvn clean install -DskipTests'
                }
            }
        }

        stage('Test & Jacoco Report') {
            steps {
                dir('server/activities_service') {
                    sh 'mvn org.jacoco:jacoco-maven-plugin:0.8.11:prepare-agent test org.jacoco:jacoco-maven-plugin:0.8.11:report -Dtest=!ActivitiesServiceApplicationTests || true'
                }
                dir('server/movement_service') {
                    sh 'mvn org.jacoco:jacoco-maven-plugin:0.8.11:prepare-agent test org.jacoco:jacoco-maven-plugin:0.8.11:report -Dtest=!MovementServiceApplicationTests || true'
                }
            }
            post {
                always {
                    junit allowEmptyResults: true,
                            testResults: 'server/**/target/surefire-reports/*.xml'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    dir('server/activities_service') {
                        sh "mvn sonar:sonar -Dsonar.projectKey=activities-service -Dsonar.projectName='Activities Service' -Dsonar.coverage.jacoco.xmlReportPaths=${WORKSPACE}/server/activities_service/target/site/jacoco/jacoco.xml"
                    }
                    dir('server/movement_service') {
                        sh "mvn sonar:sonar -Dsonar.projectKey=movement-service -Dsonar.projectName='Movement Service' -Dsonar.coverage.jacoco.xmlReportPaths=${WORKSPACE}/server/movement_service/target/site/jacoco/jacoco.xml"
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 2, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: false
                }
            }
        }

        stage('Docker Build & Push Harbor') {
            steps {
                // ICI : J'ai rajouté 'withCredentials([usernamePassword(' qui manquait
                withCredentials([usernamePassword(
                        credentialsId: 'harbor-creds',
                        usernameVariable: 'HARBOR_USER',
                        passwordVariable: 'HARBOR_PASS'
                )]) {
                    sh """
                        docker login localhost:8085 -u ${HARBOR_USER} -p ${HARBOR_PASS}
                        
                        docker build -t localhost:8085/mindcare/activities-service:1.0 server/activities_service/
                        docker push localhost:8085/mindcare/activities-service:1.0
                        
                        docker build -t localhost:8085/mindcare/movement-service:1.0 server/movement_service/
                        docker push localhost:8085/mindcare/movement-service:1.0
                    """
                }
            }
        }
    }

    post {
        success {
            echo '✅ Pipeline terminé avec succès ! Outil M3 utilisé.'
        }
        failure {
            echo '❌ Échec du pipeline. Vérifie la configuration de M3 ou les logs.'
        }
    }
}