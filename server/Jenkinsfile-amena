pipeline {
    agent any

    tools {
        maven 'Maven'
    }

    environment {
        // Configuration SonarQube
        SONAR_HOST_URL  = 'http://host.docker.internal:9091'
        IMAGE_TAG       = '1.0'

        // Configuration Harbor
        HARBOR_URL      = 'localhost:8085'
        HARBOR_PROJECT  = 'mindcare'

        // Configuration MySQL pour Jenkins (Lien vers ton Windows Host)
        DB_USER         = 'root'
        DB_PASS         = ''
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Start SonarQube') {
            steps {
                sh '''
                    sudo sysctl -w vm.max_map_count=262144 || true
                    if [ $(docker ps -q -f name=sonarqube) ]; then
                        echo "SonarQube is already running."
                    elif [ $(docker ps -aq -f name=sonarqube) ]; then
                        echo "Starting existing SonarQube container..."
                        docker start sonarqube
                    else
                        echo "Launching new SonarQube container..."
                        docker run -d --name sonarqube -p 9091:9000 \
                            -e SONAR_ES_BOOTSTRAP_CHECKS_DISABLE=true \
                            sonarqube:community
                    fi
                '''
            }
        }

        stage('Build & Install Parent') {
            steps {
                dir('server') {
                    // On installe le parent en sautant les tests pour garantir les dépendances inter-modules
                    sh 'mvn clean install -DskipTests'
                }
            }
        }

        stage('Test & Report: Activities Service') {
            steps {
                dir('server/activities_service') {
                    // On utilise env.DB_USER et env.DB_PASS pour éviter l'erreur MissingPropertyException
                    sh """
                        mvn clean test jacoco:report \
                        -DACTIVITIES_DB_URL=jdbc:mysql://host.docker.internal:3306/activities_db?createDatabaseIfNotExist=true \
                        -DDB_USERNAME=${env.DB_USER} \
                        -DDB_PASSWORD=${env.DB_PASS}
                    """
                }
            }
            post {
                always {
                    junit allowEmptyResults: true,
                            testResults: 'server/activities_service/target/surefire-reports/*.xml'
                }
            }
        }

        stage('Test & Report: Movement Service') {
            steps {
                dir('server/movement_service') {
                    sh """
                        mvn clean test jacoco:report \
                        -DMOVEMENT_DB_URL=jdbc:mysql://host.docker.internal:3306/movement_db?createDatabaseIfNotExist=true \
                        -DDB_USERNAME=${env.DB_USER} \
                        -DDB_PASSWORD=${env.DB_PASS}
                    """
                }
            }
            post {
                always {
                    junit allowEmptyResults: true,
                            testResults: 'server/movement_service/target/surefire-reports/*.xml'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                sleep 20
                withSonarQubeEnv('SonarQube') {
                    sh """
                        mvn -f server/activities_service/pom.xml sonar:sonar \
                            -Dsonar.projectKey=activities-service \
                            -Dsonar.projectName='Activities Service' \
                            -Dsonar.host.url=${env.SONAR_HOST_URL} \
                            -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml

                        mvn -f server/movement_service/pom.xml sonar:sonar \
                            -Dsonar.projectKey=movement-service \
                            -Dsonar.projectName='Movement Service' \
                            -Dsonar.host.url=${env.SONAR_HOST_URL} \
                            -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml
                    """
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: false
                }
            }
        }

        stage('Docker Build & Push') {
            steps {
                withCredentials([usernamePassword(
                        credentialsId: 'harbor-creds',
                        usernameVariable: 'HARBOR_USER',
                        passwordVariable: 'HARBOR_PASS'
                )]) {
                    sh """
                        docker login ${env.HARBOR_URL} -u ${HARBOR_USER} -p ${HARBOR_PASS}

                        # Build et Push Activities
                        docker build -t ${env.HARBOR_URL}/${env.HARBOR_PROJECT}/activities-service:${env.IMAGE_TAG} server/activities_service/
                        docker push ${env.HARBOR_URL}/${env.HARBOR_PROJECT}/activities-service:${env.IMAGE_TAG}

                        # Build et Push Movement
                        docker build -t ${env.HARBOR_URL}/${env.HARBOR_PROJECT}/movement-service:${env.IMAGE_TAG} server/movement_service/
                        docker push ${env.HARBOR_URL}/${env.HARBOR_PROJECT}/movement-service:${env.IMAGE_TAG}
                    """
                }
            }
        }
    }

    post {
        success {
            echo '✅ SUCCÈS : Tests MySQL validés, Sonar terminé et images poussées sur Harbor !'
        }
        failure {
            echo '❌ ÉCHEC : Vérifie les logs Maven ou la connexion host.docker.internal.'
            sh 'docker stop sonarqube || true'
        }
    }
}