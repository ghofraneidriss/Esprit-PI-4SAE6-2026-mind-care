pipeline {
    agent any

    environment {
        MAVEN_HOME = '/usr/share/maven'
        JAVA_HOME = '/usr/lib/jvm/java-21-openjdk-amd64'
    }

    stages {
        stage('Checkout') {
            steps {
                echo '========== Checking out code =========='
                checkout scm
            }
        }

        stage('Build') {
            steps {
                echo '========== Building followup-alert-service =========='
                dir('server/followup-alert-service') {
                    sh 'mvn clean compile'
                }
            }
        }

        stage('Test') {
            steps {
                echo '========== Running Unit Tests =========='
                dir('server/followup-alert-service') {
                    sh 'mvn test'
                }
            }
        }

        stage('Package') {
            steps {
                echo '========== Packaging Application =========='
                dir('server/followup-alert-service') {
                    sh 'mvn package -DskipTests'
                }
            }
        }
    }

    post {
        always {
            echo '========== Pipeline Execution Completed =========='
            junit 'server/followup-alert-service/target/surefire-reports/*.xml'
        }
        success {
            echo '✓ followup-alert-service pipeline SUCCESS'
        }
        failure {
            echo '✗ followup-alert-service pipeline FAILED'
        }
    }
}
