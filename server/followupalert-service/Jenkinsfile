pipeline {
    agent any

    environment {
        MAVEN_HOME = '/usr/share/maven'
        JAVA_HOME = '/usr/lib/jvm/java-21-openjdk-amd64'
        SERVICE_NAME = 'followup-alert-service'
        DOCKER_REGISTRY = 'ghofraneidriss'
        IMAGE_TAG = "${BUILD_NUMBER}"
        SONARQUBE_TOKEN = 'squ_e0870cc0c2431c7ce7a9f781d2de7d8452f706ec'
    }

    options {
        timestamps()
        timeout(time: 1, unit: 'HOURS')
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {
        stage('Checkout') {
            steps {
                echo '🔄 Checking out code...'
                cleanWs()
                checkout scm
            }
        }

        stage('Build') {
            steps {
                echo '🔨 Building Maven project...'
                dir('server/followupalert-service') {
                    sh 'mvn clean compile'
                }
            }
        }

        stage('Test') {
            steps {
                echo '🧪 Running tests...'
                dir('server/followupalert-service') {
                    sh 'mvn test'
                    junit 'target/surefire-reports/*.xml'
                }
            }
        }

        stage('Package') {
            steps {
                echo '📦 Packaging application...'
                dir('server/followupalert-service') {
                    sh 'mvn package -DskipTests'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                echo '📊 Running SonarQube analysis...'
                dir('server/followupalert-service') {
                    sh '''
                        mvn sonar:sonar \
                          -Dsonar.projectKey=followup-alert-service \
                          -Dsonar.sources=src/main \
                          -Dsonar.tests=src/test \
                          -Dsonar.host.url=http://localhost:9000 \
                          -Dsonar.token=${SONARQUBE_TOKEN} \
                          || echo "SonarQube analysis skipped (server unavailable or auth failed)"
                    '''
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                echo '🐳 Building Docker image...'
                dir('server/followupalert-service') {
                    script {
                        sh '''
                            docker build \
                              -t ${DOCKER_REGISTRY}/${SERVICE_NAME}:${IMAGE_TAG} \
                              -t ${DOCKER_REGISTRY}/${SERVICE_NAME}:latest \
                              --label "build.number=${BUILD_NUMBER}" \
                              --label "git.commit=${GIT_COMMIT}" \
                              --label "jenkins.job=${JOB_NAME}" \
                              .
                        '''
                    }
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                echo '📤 Pushing Docker image to registry...'
                script {
                    sh '''
                        docker push ${DOCKER_REGISTRY}/${SERVICE_NAME}:${IMAGE_TAG} || echo "Docker push skipped (no credentials configured)"
                        docker push ${DOCKER_REGISTRY}/${SERVICE_NAME}:latest || echo "Docker push skipped (no credentials configured)"
                    '''
                }
            }
        }

        stage('Deploy') {
            steps {
                echo '🚀 Deploying service...'
                script {
                    sh '''
                        cd ${WORKSPACE}
                        docker-compose down --remove-orphans 2>/dev/null || true
                        docker container prune -f 2>/dev/null || true
                        docker volume prune -f 2>/dev/null || true
                        docker network prune -f 2>/dev/null || true
                        sleep 2
                        docker-compose up -d
                        sleep 10
                        docker-compose logs followup-alert-service
                    '''
                }
            }
        }

        stage('Health Check') {
            steps {
                echo '❤️ Performing health checks...'
                script {
                    sh '''
                        MAX_RETRIES=30
                        RETRY_COUNT=0

                        while [ $RETRY_COUNT -lt $MAX_RETRIES ]; do
                            if nc -z localhost 8090 2>/dev/null; then
                                echo "✅ Service is healthy!"
                                exit 0
                            fi
                            RETRY_COUNT=$((RETRY_COUNT + 1))
                            echo "Health check attempt $RETRY_COUNT/$MAX_RETRIES..."
                            sleep 2
                        done

                        echo "❌ Service failed health check"
                        exit 1
                    '''
                }
            }
        }
    }

    post {
        always {
            echo '📝 Pipeline completed'
        }
        success {
            echo '✅ Pipeline completed successfully!'
        }
        failure {
            echo '❌ Pipeline failed!'
        }
    }
}
