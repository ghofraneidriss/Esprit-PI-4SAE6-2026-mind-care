# MindCare — registre des ports HTTP (référence dev / IntelliJ / scripts)
# Ordre de démarrage conseillé : MySQL → Eureka → microservices → API Gateway → Angular

# Découverte de services (lb:// dans l’API Gateway)
EUREKA_PORT=8761

# Point d’entrée unique pour le front (proxy ng serve → ce port pour tout sauf /api/users en direct)
API_GATEWAY_PORT=8080

# Microservices métier (spring.application.name = valeur lb:// dans le gateway)
USERS_SERVICE_PORT=8081          # users-service        — DB: alzheimer_db
FORUMS_SERVICE_PORT=8082         # forums-service       — DB: forum_db
INCIDENT_SERVICE_PORT=8083       # incident-service     — DB: incident_db
ACTIVITIES_SERVICE_PORT=8084     # activities-service   — DB: activities_db
LOCALIZATION_SERVICE_PORT=8085   # localization-service — DB: localization_db
MOVEMENT_SERVICE_PORT=8086       # movement-service     — DB: movement_db
RECOMMENDATION_SERVICE_PORT=8087 # recommendation-service — DB: recommendation_db
SOUVENIR_SERVICE_PORT=8088       # souvenir-service       — DB: souvenir_db

# Base de données
MYSQL_PORT=3306
