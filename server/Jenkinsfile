pipeline {
    agent any

    tools {
        // Utilisation de ton outil configuré 'M3'
        maven 'M3'
    }

    stages {
        stage('Cleanup') {
            steps {
                sh 'find . -name "report-task.txt" -delete'
            }
        }

        stage('Checkout') {
            steps {
                git branch: 'Amena-Farah-Finale',
                    url: 'https://github.com/ghofraneidriss/Esprit-PI-4SAE6-2026-mind-care.git'
            }
        }

        stage('Build & Install Parent') {
            steps {
                dir('server') {
                    sh 'mvn clean install -DskipTests'
                }
            }
        }

        stage('Test & Jacoco Report') {
            steps {
                // On utilise || true pour que le pipeline ne s'arrête pas si les tests échouent
                dir('server/activities_service') {
                    sh 'mvn org.jacoco:jacoco-maven-plugin:0.8.11:prepare-agent test org.jacoco:jacoco-maven-plugin:0.8.11:report -Dsurefire.failIfNoSpecifiedTests=false || true'
                }
                dir('server/movement_service') {
                    sh 'mvn org.jacoco:jacoco-maven-plugin:0.8.11:prepare-agent test org.jacoco:jacoco-maven-plugin:0.8.11:report -Dsurefire.failIfNoSpecifiedTests=false || true'
                }
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: 'server/**/target/surefire-reports/*.xml'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                // catchError permet de continuer même si la connexion à Sonar (port 9091) échoue
                catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                    withSonarQubeEnv('SonarQube') {
                        dir('server/activities_service') {
                            sh "mvn sonar:sonar -Dsonar.projectKey=activities-service -Dsonar.projectName='Activities Service' -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml"
                        }
                        dir('server/movement_service') {
                            sh "mvn sonar:sonar -Dsonar.projectKey=movement-service -Dsonar.projectName='Movement Service' -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml"
                        }
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                // On attend 2 min, mais on n'arrête pas le pipeline (abortPipeline: false)
                timeout(time: 2, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: false
                }
            }
        }

        stage('Docker Build & Push Harbor') {
            steps {
                withCredentials([usernamePassword(
                        credentialsId: 'harbor-creds',
                        usernameVariable: 'HARBOR_USER',
                        passwordVariable: 'HARBOR_PASS'
                )]) {
                    sh """
                        # Connexion à ton Harbor local
                        docker login localhost:8085 -u ${HARBOR_USER} -p ${HARBOR_PASS}

                        # Build et Push Activities
                        docker build -t localhost:8085/mindcare/activities-service:1.0 server/activities_service/
                        docker push localhost:8085/mindcare/activities-service:1.0

                        # Build et Push Movement
                        docker build -t localhost:8085/mindcare/movement-service:1.0 server/movement_service/
                        docker push localhost:8085/mindcare/movement-service:1.0
                    """
                }
            }
        }
    }

    post {
        success {
            echo '✅ Pipeline terminé ! Vérifie Harbor sur localhost:8085'
        }
        failure {
            echo '❌ Pipeline échoué. Regarde les logs pour voir quelle étape a bloqué.'
        }
    }
}