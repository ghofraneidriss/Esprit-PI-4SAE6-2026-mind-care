pipeline {
    agent any

    environment {
        SERVICE_NAME = 'mind-care-frontend'
        DOCKER_REGISTRY = 'ghofraneidriss'
        IMAGE_TAG = "${BUILD_NUMBER}"
        GIT_SSL_NO_VERIFY = 'true'
        GIT_TRACE = '1'
        GIT_HTTP_LOW_SPEED_LIMIT = '0'
        GIT_HTTP_LOW_SPEED_TIME = '0'
        GIT_TERMINAL_PROMPT = 'false'
    }

    options {
        timestamps()
        timeout(time: 1, unit: 'HOURS')
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {
        stage('Build with Docker') {
            steps {
                echo '🔨 Building Angular project with Docker...'
                dir('front') {
                    sh '''
                        docker build \
                          -t ${DOCKER_REGISTRY}/${SERVICE_NAME}:build-${BUILD_NUMBER} \
                          --target builder \
                          .
                    '''
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                echo '🐳 Building Docker image...'
                dir('front') {
                    script {
                        sh '''
                            docker build \
                              -t ${DOCKER_REGISTRY}/${SERVICE_NAME}:${IMAGE_TAG} \
                              -t ${DOCKER_REGISTRY}/${SERVICE_NAME}:latest \
                              --label "build.number=${BUILD_NUMBER}" \
                              --label "git.commit=${GIT_COMMIT}" \
                              --label "jenkins.job=${JOB_NAME}" \
                              .
                        '''
                    }
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                echo '📤 Pushing Docker image to registry...'
                script {
                    sh '''
                        docker push ${DOCKER_REGISTRY}/${SERVICE_NAME}:${IMAGE_TAG} || echo "Docker push skipped (no credentials configured)"
                        docker push ${DOCKER_REGISTRY}/${SERVICE_NAME}:latest || echo "Docker push skipped (no credentials configured)"
                    '''
                }
            }
        }

        stage('Deploy') {
            steps {
                echo '🚀 Deploying frontend...'
                script {
                    sh '''
                        cd ${WORKSPACE}
                        docker stop alzcare-frontend 2>/dev/null || true
                        docker rm -f alzcare-frontend 2>/dev/null || true
                        docker run -d \
                          --name alzcare-frontend \
                          --network mindcare-network \
                          -p 80:80 \
                          ${DOCKER_REGISTRY}/${SERVICE_NAME}:${IMAGE_TAG}
                        sleep 5
                        docker logs alzcare-frontend
                    '''
                }
            }
        }

        stage('Health Check') {
            steps {
                echo '❤️ Performing health checks...'
                script {
                    sh '''
                        MAX_RETRIES=30
                        RETRY_COUNT=0

                        while [ $RETRY_COUNT -lt $MAX_RETRIES ]; do
                            if curl -f http://localhost/health 2>/dev/null | grep -q "healthy"; then
                                echo "✅ Frontend is healthy!"
                                exit 0
                            fi
                            RETRY_COUNT=$((RETRY_COUNT + 1))
                            echo "Health check attempt $RETRY_COUNT/$MAX_RETRIES..."
                            sleep 2
                        done

                        echo "❌ Frontend failed health check"
                        exit 1
                    '''
                }
            }
        }
    }

    post {
        always {
            echo '📝 Pipeline completed'
        }
        success {
            echo '✅ Pipeline completed successfully!'
        }
        failure {
            echo '❌ Pipeline failed!'
        }
    }
}
