pipeline {
    agent any

    tools {
        nodejs 'Node18'
        git 'git'
    }

    environment {
        DOCKER_REGISTRY = 'docker.io'
        DOCKER_CREDENTIALS = credentials('docker-credentials')
        GITHUB_REPO = 'https://github.com/ghofraneidriss/Esprit-PI-4SAE6-2026-mind-care.git'
        GITHUB_BRANCH = 'main'
    }

    stages {
        
        stage('Checkout Code') {
            steps {
                echo '📥 Cloning frontend repository...'
                git branch: "${GITHUB_BRANCH}",
                    url: "${GITHUB_REPO}"
            }
        }

        stage('Install Dependencies') {
            steps {
                echo '📦 Installing npm dependencies...'
                dir('front') {
                    sh 'npm install'
                }
            }
        }

        stage('Build Frontend') {
            steps {
                echo '🏗️ Building Angular application...'
                dir('front') {
                    sh 'npm run build -- --configuration production'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                echo '🐳 Building frontend Docker image...'
                sh '''
                    cd front
                    docker build -t ${DOCKER_REGISTRY}/ghofrane/mindcare-frontend:${BUILD_NUMBER} .
                    docker tag ${DOCKER_REGISTRY}/ghofrane/mindcare-frontend:${BUILD_NUMBER} ${DOCKER_REGISTRY}/ghofrane/mindcare-frontend:latest
                    cd ..
                '''
            }
        }

        stage('Push to Docker Hub') {
            when {
                branch 'main'
            }
            steps {
                echo '📤 Pushing frontend image to Docker Hub...'
                sh '''
                    echo $DOCKER_CREDENTIALS_PSW | docker login -u $DOCKER_CREDENTIALS_USR --password-stdin
                    docker push ${DOCKER_REGISTRY}/ghofrane/mindcare-frontend:${BUILD_NUMBER}
                    docker push ${DOCKER_REGISTRY}/ghofrane/mindcare-frontend:latest
                    docker logout
                '''
            }
        }

        stage('Deploy Frontend') {
            when {
                branch 'main'
            }
            steps {
                echo '🚀 Deploying frontend...'
                sh '''
                    docker rm -f mindcare-frontend 2>/dev/null || true
                    docker run -d -p 80:80 --name mindcare-frontend ${DOCKER_REGISTRY}/ghofrane/mindcare-frontend:latest
                '''
            }
        }
    }

    post {
        success {
            echo '✅ Frontend pipeline completed successfully!'
        }
        failure {
            echo '❌ Frontend pipeline failed!'
        }
    }
}
